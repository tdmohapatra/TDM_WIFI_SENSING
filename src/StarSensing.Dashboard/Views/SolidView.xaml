<UserControl x:Class="StarSensing.Dashboard.Views.SolidView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ToolBtn">
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="#1a2050"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#2a3060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CC0a0e27" Padding="10,6" Margin="4"
                CornerRadius="6" BorderBrush="#2a3060" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SolidView 3D Waveform" Foreground="{StaticResource NeonCyanBrush}"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>

                <TextBlock Text="Window" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                <Button Content="100ms" Command="{Binding Window100msCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="1s" Command="{Binding Window1sCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="10s" Command="{Binding Window10sCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="30s" Command="{Binding Window30sCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="1m" Command="{Binding Window1mCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="5m" Command="{Binding Window5mCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="10m" Command="{Binding Window10mCommand}" Style="{StaticResource ToolBtn}"/>

                <Border Width="1" Background="#2a3060" Margin="10,2"/>

                <Button Content="Load History" Command="{Binding LoadHistoryCommand}" Style="{StaticResource ToolBtn}"
                        Foreground="{StaticResource NeonCyanBrush}"/>
                <Button Content="Copy Data" Command="{Binding CopyDataCommand}" Style="{StaticResource ToolBtn}"/>
                <Button Content="Save PNG" Click="OnSaveImageClicked" Style="{StaticResource ToolBtn}"
                        Foreground="#43e3a0"/>
                <Button Content="Stitch Saved" Click="OnStitchClicked" Style="{StaticResource ToolBtn}"/>
                <Button Content="Open Folder" Click="OnOpenFolderClicked" Style="{StaticResource ToolBtn}"/>

                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11"
                           Foreground="{StaticResource WarningAmberBrush}">
                    <Run Text="Window: "/>
                    <Run Text="{Binding WindowLabel, Mode=OneWay}"/>
                    <Run Text="  |  Saved: "/>
                    <Run Text="{Binding SavedImageCount, Mode=OneWay}"/>
                    <Run Text="  |  "/>
                    <Run Text="{Binding MlSummary, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <skia:SKElement Name="SolidCanvas" Grid.Row="1" PaintSurface="OnPaintSolid"
                        MouseWheel="OnCanvasWheel" Margin="4,0,4,0"/>

        <TextBlock Grid.Row="2" Margin="10,2" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Text="{Binding StatusText}"/>
    </Grid>
</UserControl>
