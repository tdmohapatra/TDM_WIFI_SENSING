<UserControl x:Class="StarSensing.Dashboard.Views.HeatmapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CC0a0e27" Padding="10,6" Margin="8,8,8,0"
                CornerRadius="6" BorderBrush="#2a3060" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Heatmap" Foreground="{StaticResource NeonCyanBrush}"
                               FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="Channel" Click="OnChannelMode" Padding="10,4" Margin="0,0,4,0"
                            Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#2a3060"/>
                    <Button Content="Spatial 3D" Click="OnSpatialMode" Padding="10,4" Margin="0,0,8,0"
                            Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="50ms" Command="{Binding SetSpatialFastStreamCommand}" Padding="8,3" Margin="0,0,8,0"
                            Background="#143a2e" Foreground="#43e3a0" BorderBrush="#1f5a47" FontSize="11"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                        <Run Text="Mode: "/>
                        <Run Text="{Binding ModeLabel, Mode=OneWay}"/>
                        <Run Text="  |  Motion: "/>
                        <Run Text="{Binding MotionConfidence, Mode=OneWay, StringFormat={}{0:F0}%}"/>
                        <Run Text="  |  Peak: "/>
                        <Run Text="{Binding PeakActivity, Mode=OneWay, StringFormat={}{0:F2}}"/>
                        <Run Text="  |  CNN: "/>
                        <Run Text="{Binding CnnActivityScore, Mode=OneWay, StringFormat={}{0:F0}%}"/>
                    </TextBlock>
                    <Button Content="Refresh Positions" Command="{Binding RefreshPositionsCommand}" Margin="12,0,0,0"
                            Padding="8,3" FontSize="11" Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                    <Button Name="FullscreenButton" Content="⛶ Fullscreen" Click="OnToggleFullscreen" Margin="6,0,0,0"
                            Padding="8,3" FontSize="11" Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#2a3060"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Live" Command="{Binding SetLiveModeCommand}" Padding="8,3" Margin="0,0,4,0"
                            Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060" FontSize="11"/>
                    <Button Content="History" Command="{Binding SetHistoricalModeCommand}" Padding="8,3" Margin="0,0,8,0"
                            Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#2a3060" FontSize="11"/>
                    <Button Content="5m" Command="{Binding TimeRange.SetRange5mCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#10173a" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="15m" Command="{Binding TimeRange.SetRange15mCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#10173a" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="30m" Command="{Binding TimeRange.SetRange30mCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#10173a" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="1h" Command="{Binding TimeRange.SetRange1hCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#10173a" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="24h" Command="{Binding TimeRange.SetRange24hCommand}" Padding="6,3" Margin="0,0,8,0" FontSize="10"
                            Background="#10173a" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="#2a3060"/>
                    <Button Content="▶" Command="{Binding Timeline.PlayCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                    <Button Content="⏸" Command="{Binding Timeline.PauseCommand}" Padding="6,3" Margin="0,0,2,0" FontSize="10"
                            Background="#1a2050" BorderBrush="#2a3060"/>
                    <Button Content="Reload" Command="{Binding ReloadTimelineCommand}" Padding="6,3" FontSize="10"
                            Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                    <TextBlock Text="{Binding TimeModeLabel}" Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource NeonCyanBrush}" FontSize="11"/>
                </StackPanel>
                <Slider Minimum="0" Maximum="100" Value="{Binding Timeline.ScrubPosition, Mode=TwoWay}"
                        Margin="0,4,0,0" Visibility="{Binding Timeline.IsHistoricalActive, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding TimelineStatus}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Name="DetailColumn" Width="250" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ScottPlot:WpfPlot Name="ChannelPlot" Margin="2"/>
                <Grid Name="SpatialPanel" Visibility="Collapsed" Margin="2">
                    <skia:SKElement Name="SpatialCanvas" PaintSurface="OnPaintSpatial"
                                    MouseWheel="OnSpatialMouseWheel"
                                    MouseDown="OnSpatialMouseDown"
                                    MouseMove="OnSpatialMouseMove"
                                    MouseUp="OnSpatialMouseUp"/>
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8" MaxWidth="220">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="−" Click="OnZoomOut" Width="28" Height="28" Margin="0,0,4,0"
                                    Background="#CC1a2050" Foreground="#43e3a0" BorderBrush="#2a3060" FontSize="16"/>
                            <Button Content="+" Click="OnZoomIn" Width="28" Height="28" Margin="0,0,4,0"
                                    Background="#CC1a2050" Foreground="#43e3a0" BorderBrush="#2a3060" FontSize="16"/>
                            <Button Content="Reset" Click="OnZoomReset" Padding="8,4"
                                    Background="#CC1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#2a3060" FontSize="11"/>
                        </StackPanel>
                        <Border Background="#CC0a1028" CornerRadius="6" Padding="8,6" Margin="0,8,0,0"
                                BorderBrush="#2a3060" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding ViewportRangeLabel, Mode=OneWay}" Foreground="{StaticResource NeonCyanBrush}" FontSize="10" FontWeight="SemiBold"/>
                                <Slider Minimum="0.1" Maximum="50" Value="{Binding ViewportMeters, Mode=TwoWay}"
                                        TickFrequency="5" IsSnapToTickEnabled="False" Margin="0,4,0,0"/>
                                <TextBlock Text="10 cm ← range → 50 m" Foreground="#6a7599" FontSize="9" Margin="0,2,0,0"/>
                                <Button Content="Ping motion zone" Command="{Binding PingSelectedZoneCommand}" Margin="0,8,0,0"
                                        Padding="8,4" Background="#143a2e" Foreground="#43e3a0" BorderBrush="#1f5a47" FontSize="11"/>
                                <TextBlock Text="{Binding ProbeStatus}" Foreground="#8b95c9" FontSize="9" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Name="ApListPanel" Visibility="Collapsed"
                    Background="#10173a" BorderBrush="#2a3060" BorderThickness="1" CornerRadius="6" Margin="4,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Detection Blocks" FontWeight="Bold"
                               Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Live now: pulsing amber/red columns · bars show Motion (amber) vs Occupancy (cyan) · 28s trails: amber=movement, violet=obstacle."
                               Foreground="#8b95c9" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <ListView Grid.Row="2" ItemsSource="{Binding BlockZones}" MaxHeight="180"
                              SelectedValue="{Binding SelectedZoneId, Mode=TwoWay}"
                              SelectedValuePath="ZoneId"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextPrimaryBrush}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6" BorderBrush="#2a3060" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary, Mode=OneWay}" FontSize="10" Foreground="{StaticResource WarningAmberBrush}"/>
                                        <TextBlock Text="{Binding DistanceLabel, Mode=OneWay}" FontSize="10" Foreground="#43e3a0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,4">
                        <TextBlock Text="Learned areas" FontWeight="Bold"
                                   Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center"/>
                        <Button Content="Clear" Command="{Binding ClearSpatialMemoryCommand}" Margin="8,0,0,0"
                                Padding="6,2" FontSize="10" Background="#1a2050" Foreground="#8b95c9" BorderBrush="#2a3060"/>
                    </StackPanel>
                    <TextBlock Grid.Row="4" Text="History/ghost layer — dashed rings, persists between sessions: blue=motion memory, slate=obstacle memory."
                               Foreground="#8b95c9" FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    <ListView Grid.Row="5" ItemsSource="{Binding CommonHotspots}" MinHeight="120"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextPrimaryBrush}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6" BorderBrush="#2a3060" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}">
                                            <Run Text="{Binding Label, Mode=OneWay}"/>
                                            <Run Text=" · " Foreground="#6a7599"/>
                                            <Run Text="{Binding DistanceLabel, Mode=OneWay}" Foreground="#43e3a0"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Summary, Mode=OneWay}" FontSize="10" Foreground="#8b95c9" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
