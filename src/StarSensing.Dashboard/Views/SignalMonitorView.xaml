<UserControl x:Class="StarSensing.Dashboard.Views.SignalMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#121a40"/>
            <Setter Property="BorderBrush" Value="#243064"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Title + actions ── -->
        <Grid Grid.Row="0" Margin="6,0,6,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="SIGNAL MONITOR" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource NeonCyanBrush}"/>
                <TextBlock Text="Live network overview" FontSize="12" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Select All" Command="{Binding SelectAllCommand}" Padding="10,4" FontSize="11"
                        Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}"
                        BorderBrush="#2a3060" BorderThickness="1" Cursor="Hand"/>
                <Button Content="Deselect All" Command="{Binding UnselectAllCommand}" Padding="10,4" FontSize="11" Margin="4,0,0,0"
                        Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="#2a3060" BorderThickness="1" Cursor="Hand"/>
                <Button Content="50ms" Click="OnRate50Clicked" Padding="10,4" FontSize="11" Margin="10,0,0,0"
                        Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}"
                        BorderBrush="#2a3060" BorderThickness="1" Cursor="Hand"/>
                <Button Content="100ms" Click="OnRate100Clicked" Padding="10,4" FontSize="11" Margin="4,0,0,0"
                        Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="#2a3060" BorderThickness="1" Cursor="Hand"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,4" FontSize="11" Margin="10,0,0,0"
                        Background="#143a2e" Foreground="#43e3a0"
                        BorderBrush="#1f5a47" BorderThickness="1" Cursor="Hand"/>
                <Button Content="Reload Page" Command="{Binding ReloadPageCommand}" Padding="12,4" FontSize="11" Margin="4,0,0,0"
                        Background="#3a2a14" Foreground="{StaticResource WarningAmberBrush}"
                        BorderBrush="#5a451f" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- ── KPI cards ── -->
        <UniformGrid Grid.Row="1" Columns="9">
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="TOTAL IDENTIFIED" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding NetworkCount, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="devices seen" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="LIVE / ONLINE" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding OnlineCount, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                               Foreground="#43e3a0"/>
                    <TextBlock Text="active now" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="OFFLINE" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding OfflineCount, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                               Foreground="#ef6a6a"/>
                    <TextBlock Text="not seen recently" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="UPTIME" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding UptimeText, Mode=OneWay}" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource NeonCyanBrush}"/>
                    <TextBlock Text="session running" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="REFRESHES" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding RefreshCount, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="next in "/>
                        <Run Text="{Binding SecondsToRefresh, Mode=OneWay}"/>
                        <Run Text="s"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="LAST REFRESH" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding LastRefreshText, Mode=OneWay}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="auto every 2s" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="MOTION" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MotionConfidencePct, Mode=OneWay, StringFormat={}{0:F0}%}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource WarningAmberBrush}"/>
                    <TextBlock Text="ML confidence" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="LSTM "/>
                        <Run Text="{Binding LstmMotionPct, Mode=OneWay, StringFormat={}{0:F0}%}"/>
                        <Run Text=" · CNN "/>
                        <Run Text="{Binding CnnActivityPct, Mode=OneWay, StringFormat={}{0:F0}%}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="STABILITY" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding StabilityPct, Mode=OneWay, StringFormat={}{0:F0}%}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource NeonCyanBrush}"/>
                    <TextBlock Text="signal entropy" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="ANOMALIES" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AnomalyCount, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                               Foreground="#ef4444"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="zones "/>
                        <Run Text="{Binding ActiveZoneCount, Mode=OneWay}"/>
                        <Run Text=" | corr "/>
                        <Run Text="{Binding AvgCrossCorrelation, Mode=OneWay, StringFormat={}{0:F2}}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ── Search + Save-to-location ── -->
        <Grid Grid.Row="2" Margin="6,8,6,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="SearchBox" Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" VerticalContentAlignment="Center" Padding="8,0"
                         Background="#10173a" BorderBrush="#2a3060"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="0" IsHitTestVisible="False" Text="Type to search SSID, BSSID, band, direction, model..."
                           Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#5b6699" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Location" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="6,0"
                         Text="{Binding LocationName, UpdateSourceTrigger=PropertyChanged}"
                         Background="#10173a" BorderBrush="#2a3060"
                         Foreground="{StaticResource TextPrimaryBrush}"/>
                <Button Grid.Column="2" Content="Save Location" Command="{Binding SaveLocationCommand}"
                        Padding="14,5" Margin="8,0,0,0"
                        Background="#143a2e" Foreground="#43e3a0"
                        BorderBrush="#1f5a47" BorderThickness="1" Cursor="Hand"/>
                <TextBlock Grid.Column="3" Text="{Binding SaveStatusText}" VerticalAlignment="Center"
                           Margin="12,0,0,0" FontSize="11"
                           Foreground="{StaticResource WarningAmberBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Grid>

        <!-- ── Data tabs (Live list + History) ── -->
        <TabControl Grid.Row="3" Margin="6,4,6,0" Background="Transparent">
            <TabItem Header="Live Devices">
                <ListView Name="LiveListView" Background="Transparent" BorderBrush="#1e2545" BorderThickness="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="SSID" Width="160" DisplayMemberBinding="{Binding Ssid}"/>
                            <GridViewColumn Header="BSSID" Width="130" DisplayMemberBinding="{Binding Bssid}"/>
                            <GridViewColumn Header="Distance" Width="80" DisplayMemberBinding="{Binding DistanceText}"/>
                            <GridViewColumn Header="Direction" Width="90" DisplayMemberBinding="{Binding DirectionText}"/>
                            <GridViewColumn Header="RSSI" Width="70" DisplayMemberBinding="{Binding RssiText}"/>
                            <GridViewColumn Header="Var" Width="55" DisplayMemberBinding="{Binding VarianceText}"/>
                            <GridViewColumn Header="Entropy" Width="60" DisplayMemberBinding="{Binding EntropyText}"/>
                            <GridViewColumn Header="Gradient" Width="75" DisplayMemberBinding="{Binding ChangeRateText}"/>
                            <GridViewColumn Header="Corr" Width="50" DisplayMemberBinding="{Binding CrossCorrelationText}"/>
                            <GridViewColumn Header="Motion" Width="60" DisplayMemberBinding="{Binding MotionConfidenceText}"/>
                            <GridViewColumn Header="Quality" Width="70" DisplayMemberBinding="{Binding SignalQualityText}"/>
                            <GridViewColumn Header="Band/Ch" Width="100" DisplayMemberBinding="{Binding BandChannelText}"/>
                            <GridViewColumn Header="Model / Type" Width="160" DisplayMemberBinding="{Binding ModelText}"/>
                            <GridViewColumn Header="Last Seen" Width="100" DisplayMemberBinding="{Binding LastSeenText}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="History (All Identified)">
                <DataGrid Name="HistoryDataGrid"
                          AutoGenerateColumns="False" HeadersVisibility="Column"
                          IsReadOnly="True" CanUserAddRows="False"
                          Background="#10173a" BorderBrush="#1e2545"
                          Foreground="{StaticResource TextPrimaryBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeenText}" Width="100"/>
                        <DataGridTextColumn Header="First Seen" Binding="{Binding FirstSeenText}" Width="100"/>
                        <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="160"/>
                        <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="140"/>
                        <DataGridTextColumn Header="Distance" Binding="{Binding DistanceText}" Width="80"/>
                        <DataGridTextColumn Header="Direction" Binding="{Binding DirectionText}" Width="80"/>
                        <DataGridTextColumn Header="Model / Type" Binding="{Binding ModelText}" Width="160"/>
                        <DataGridTextColumn Header="RSSI Range" Binding="{Binding RssiRangeText}" Width="100"/>
                        <DataGridTextColumn Header="Variance" Binding="{Binding VarianceText}" Width="60"/>
                        <DataGridTextColumn Header="Entropy" Binding="{Binding EntropyText}" Width="60"/>
                        <DataGridTextColumn Header="Gradient" Binding="{Binding ChangeRateText}" Width="80"/>
                        <DataGridTextColumn Header="Corr" Binding="{Binding CrossCorrelationText}" Width="50"/>
                        <DataGridTextColumn Header="Motion" Binding="{Binding MotionConfidenceText}" Width="60"/>
                        <DataGridTextColumn Header="Anomaly" Binding="{Binding AnomalyText}" Width="60"/>
                        <DataGridTextColumn Header="Samples" Binding="{Binding SampleCountText}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
