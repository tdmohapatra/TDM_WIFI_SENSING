<UserControl x:Class="StarSensing.Dashboard.Views.AreaMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">

    <Grid Background="#060912">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <skia:SKElement Name="MapCanvas"
                        Grid.Column="0" Grid.Row="1"
                        PaintSurface="OnPaintMap"
                        MouseWheel="OnMapMouseWheel"
                        Margin="0"/>

        <Border Grid.Column="0" Grid.Row="0"
                Margin="6,6,4,4" Padding="10,6"
                Background="#E0081028" CornerRadius="6"
                BorderBrush="#3a4880" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Area Map"
                               Foreground="{StaticResource NeonCyanBrush}"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock Foreground="#b8c4e8" FontSize="11">
                        <Run Text="{Binding Classification}"/>
                        <Run Text=" · Motion "/>
                        <Run Text="{Binding MotionConfidence, StringFormat={}{0:F0}%}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding ActiveApCount}"/>
                        <Run Text=" APs · "/>
                        <Run Text="{Binding ActiveZoneCount}"/>
                        <Run Text=" zones"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="50ms" Click="OnRate50Clicked" Width="46" Height="26" Margin="0,0,4,0"
                            Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                    <Button Content="100ms" Click="OnRate100Clicked" Width="50" Height="26" Margin="0,0,8,0"
                            Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                    <Button Content="Live" Click="OnLiveModeClicked" Width="44" Height="26" Margin="0,0,12,0"
                            Background="#143a2e" Foreground="#43e3a0" BorderBrush="#1f5a47" BorderThickness="1"/>
                    <Button Name="MotionModeToggleBtn" Content="3D + APs" Click="OnToggleMotionModeClicked" Width="72" Height="26" Margin="0,0,8,0"
                            Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1" FontSize="10"/>
                    <Button Content="Selected" Click="OnSourceSelectedClicked" Width="68" Height="26" Margin="0,0,4,0"
                            Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                    <Button Content="All" Click="OnSourceAllClicked" Width="40" Height="26" Margin="0,0,4,0"
                            Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                    <Button Content="Connected" Click="OnSourceConnectedClicked" Width="76" Height="26"
                            Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Foreground="{StaticResource WarningAmberBrush}" FontSize="11" HorizontalAlignment="Right">
                        <Run Text="M:"/><Run Text="{Binding MeasurementLatencyMs, StringFormat={}{0:F0}ms}"/>
                        <Run Text=" E:"/><Run Text="{Binding EnvironmentLatencyMs, StringFormat={}{0:F0}ms}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding TimeFrameText, Mode=OneWay}" Foreground="#8b95c9" FontSize="11" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="12" Grid.Column="0" Grid.Row="1">
            <Button Content="+" Width="40" Height="34" Click="OnZoomInClicked"
                    Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1" FontSize="16" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="−" Width="40" Height="34" Margin="0,6,0,0" Click="OnZoomOutClicked"
                    Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1" FontSize="16" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="Fit" Width="40" Height="28" Margin="0,6,0,0" Click="OnFitClicked"
                    Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="Reset" Width="40" Height="28" Margin="0,6,0,0" Click="OnResetZoomClicked"
                    Background="#1a2050" Foreground="#8b95c9" BorderBrush="#3a4880" BorderThickness="1" FontSize="10" Cursor="Hand"/>
            <Button Name="LabelsToggleBtn" Content="Labels: ON" Width="76" Height="28" Margin="0,6,0,0"
                    Click="OnToggleLabelsClicked" Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}"
                    BorderBrush="#3a4880" BorderThickness="1" FontSize="10" Cursor="Hand"/>
        </StackPanel>

        <TextBlock Grid.Column="0" Grid.Row="2" Margin="10,0" VerticalAlignment="Center"
                   Foreground="#6a7599" FontSize="10"
                   Text="Drag=orbit · Shift/right-drag=pan · Wheel=zoom · Double-click=fit · Hover AP/zone · Toggle Motion only for zones-only view"/>

        <Border Grid.Column="1" Grid.RowSpan="3" Margin="4,6,6,6" Padding="10"
                Background="#E0081028" CornerRadius="8" BorderBrush="#3a4880" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Expander Grid.Row="0" Header="Direction calibration" IsExpanded="False" Margin="0,0,0,8"
                          Foreground="{StaticResource NeonCyanBrush}" FontWeight="SemiBold">
                    <StackPanel Margin="0,8,0,0">
                        <CheckBox Content="Calibration mode (click AP)" IsChecked="{Binding CalibrationMode, Mode=TwoWay}"
                                  Foreground="#b8c4e8" FontSize="11" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding CalibrationTarget.Ssid, TargetNullValue='Click an AP on the map'}"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <Slider Minimum="0" Maximum="359" Value="{Binding CalibrationBearing, Mode=TwoWay}" Margin="0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Save" Command="{Binding SaveCalibrationBearingCommand}" Padding="8,4" FontSize="11"
                                    Background="#143a2e" Foreground="#43e3a0" BorderBrush="#1f5a47" BorderThickness="1"/>
                            <Button Content="Compass" Command="{Binding CaptureCompassBearingCommand}" Padding="8,4" Margin="6,0,0,0" FontSize="11"
                                    Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#3a4880" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Activity Zones" Foreground="{StaticResource NeonCyanBrush}"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Live zones from ML pipeline — occupancy and motion confidence."
                                   Foreground="#8b95c9" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding ActiveZones}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0a1028" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                            BorderBrush="#243064" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                            <TextBlock Text="{Binding Summary}" Foreground="#8b95c9" FontSize="10" Margin="0,2,0,4"/>
                                            <ProgressBar Value="{Binding OccupancyPct}" Maximum="100" Height="5" Margin="0,2,0,2"
                                                         Foreground="{StaticResource NeonCyanBrush}" Background="#1a2050"/>
                                            <ProgressBar Value="{Binding MotionPct}" Maximum="100" Height="5"
                                                         Foreground="{StaticResource WarningAmberBrush}" Background="#1a2050"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
