# Copy this file to .env and adjust values for your machine.
# See SETUP_REQUIREMENTS.md for full documentation.

SETUP_INSTALL_PASSWORD=7787

SQL_SERVER=localhost
SQL_DATABASE=StarSensing
SQL_CONNECTION_STRING=Server=localhost;Database=StarSensing;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;

ENGINE_GRPC_PORT=5050
ENGINE_GRPC_URL=http://localhost:5050
SCAN_INTERVAL_MS=50
PYTHON_PROCESSOR_ADDRESS=http://localhost:5051
PYTHON_PROCESS_INTERVAL_MS=200
DATA_RETENTION_HOURS=24
MAX_AP_TRACKING_COUNT=50

PYTHON_PORT=5051
PYTHON_MODELS_DIR=models
PYTHON_TRAIN_EPOCHS=8
PYTHON_SAMPLE_RATE_HZ=10.0
PYTHON_WINDOW_SIZE=10

DASHBOARD_GRPC_URL=http://localhost:5050

DOTNET_CONFIGURATION=Release
DOTNET_ENGINE_SDK_MAJOR=8
DOTNET_DASHBOARD_SDK_MAJOR=9
PYTHON_MIN_MAJOR=3
PYTHON_MIN_MINOR=10

WINGET_DOTNET8=Microsoft.DotNet.SDK.8
WINGET_DOTNET9=Microsoft.DotNet.SDK.9
WINGET_PYTHON=Python.Python.3.12
WINGET_ODBC17=Microsoft.msodbcsql.17
