<UserControl x:Class="StarSensing.Dashboard.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF">
    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column: arc gauge + timeline -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- Arc gauge (SkiaSharp) -->
            <skia:SKElement Name="GaugeCanvas" Grid.Row="0"
                            PaintSurface="OnPaintGauge"
                            Margin="20,20,20,10"/>

            <!-- Confidence timeline (ScottPlot) -->
            <ScottPlot:WpfPlot Name="TimelinePlot" Grid.Row="1" Margin="10,0,10,10"/>
        </Grid>

        <!-- Right column: classification + active APs + events list -->
        <Grid Grid.Column="1" Margin="10,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Environment State"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock Grid.Row="1"
                       Text="{Binding Classification}"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="{StaticResource NeonCyanBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Active APs: "
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveApCount}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource WarningAmberBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="Frame:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <Button Content="50ms" Click="OnRate50Clicked" Width="50" Height="24" Margin="0,0,4,0"
                        Background="#1a2050" Foreground="{StaticResource NeonCyanBrush}" BorderBrush="#2a3060" BorderThickness="1"/>
                <Button Content="100ms" Click="OnRate100Clicked" Width="56" Height="24" Margin="0,0,10,0"
                        Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#2a3060" BorderThickness="1"/>
                <TextBlock Text="Latency:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <TextBlock Text="{Binding StreamLatencyMs, StringFormat={}{0:F0}ms}"
                           Foreground="{StaticResource WarningAmberBrush}"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"/>
                <TextBlock Text="Last Update:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>
                <TextBlock Text="{Binding LastUpdateText}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Micro-change sensitivity:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Slider Minimum="10" Maximum="95"
                        Value="{Binding MicroSensitivity, Mode=TwoWay}"
                        Width="180"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MicroSensitivity, StringFormat={}{0}%}"
                           Foreground="{StaticResource NeonCyanBrush}"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center">
                        <Run Text="Entropy peak: "/>
                        <Run Text="{Binding PeakEntropy, StringFormat={}{0:F2}}" Foreground="{StaticResource WarningAmberBrush}"/>
                        <Run Text="  |  Stability: "/>
                        <Run Text="{Binding StabilityIndex, StringFormat={}{0:F0}%}" Foreground="{StaticResource NeonCyanBrush}"/>
                        <Run Text="  |  LSTM: "/>
                        <Run Text="{Binding LstmMotionConfidence, StringFormat={}{0:F0}%}" Foreground="#a855f7"/>
                        <Run Text="  |  CNN: "/>
                        <Run Text="{Binding CnnActivityScore, StringFormat={}{0:F0}%}" Foreground="#43e3a0"/>
                    </TextBlock>
                    <Button Content="Reload SQL" Command="{Binding LoadReplayCommand}" Margin="8,0,0,0"
                            Padding="8,3" FontSize="11" Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                </StackPanel>
                <TextBlock Text="{Binding ReplayStatus}" FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="6" Background="#10173a" BorderBrush="#2a3060" BorderThickness="1"
                    CornerRadius="6" Padding="8,6" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Time Series Replay" FontSize="12" Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Live" Command="{Binding SetLiveModeCommand}" Width="48" Height="24" Margin="0,0,4,0"
                                Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                        <Button Content="History" Command="{Binding SetHistoricalModeCommand}" Width="56" Height="24" Margin="0,0,8,0"
                                Background="#1a2050" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#2a3060"/>
                        <Button Content="5m" Command="{Binding TimeRange.SetRange5mCommand}" Width="36" Height="24" Margin="0,0,2,0" FontSize="10"
                                Background="#10173a" BorderBrush="#2a3060"/>
                        <Button Content="30m" Command="{Binding TimeRange.SetRange30mCommand}" Width="36" Height="24" Margin="0,0,2,0" FontSize="10"
                                Background="#10173a" BorderBrush="#2a3060"/>
                        <Button Content="1h" Command="{Binding TimeRange.SetRange1hCommand}" Width="36" Height="24" Margin="0,0,8,0" FontSize="10"
                                Background="#10173a" BorderBrush="#2a3060"/>
                        <Button Content="▶ Play" Command="{Binding StartReplayCommand}" Width="60" Height="24" Margin="0,0,4,0"
                                Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                        <Button Content="⏸" Command="{Binding PauseReplayCommand}" Width="40" Height="24" Margin="0,0,4,0"
                                Background="#1a2050" BorderBrush="#2a3060"/>
                        <Button Content="⏹" Command="{Binding StopReplayCommand}" Width="40" Height="24" Margin="0,0,8,0"
                                Background="#1a2050" Foreground="#ef4444" BorderBrush="#2a3060"/>
                        <Button Content="Reload SQL" Command="{Binding LoadReplayCommand}" Padding="8,3" FontSize="11"
                                Background="#1a2050" Foreground="#43e3a0" BorderBrush="#2a3060"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                            <Run Text="{Binding ReplayTimeText}"/>
                            <Run Text="  ·  "/>
                            <Run Text="{Binding ReplayFrameCount}"/>
                            <Run Text=" frames · "/>
                            <Run Text="{Binding TimeRange.ModeLabel, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Slider Minimum="0" Maximum="100" Value="{Binding ReplayPosition, Mode=TwoWay}"
                            TickFrequency="5" IsSnapToTickEnabled="False"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="7" Margin="0,0,0,8">
                <TextBlock Text="Activity Zones (KMeans)" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding Zones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#2a3060" BorderThickness="1" CornerRadius="4"
                                    Background="#10173a" Padding="6,4" Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="70"
                                               Foreground="{StaticResource NeonCyanBrush}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="Motion "/>
                                        <Run Text="{Binding MotionConfidence, StringFormat={}{0:P0}}"/>
                                        <Run Text="  Occ "/>
                                        <Run Text="{Binding OccupancyConfidence, StringFormat={}{0:P0}}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid Grid.Row="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Detection Events"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,6"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Events}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource TextSecondaryBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="4,6">
                                <StackPanel>
                                    <TextBlock Text="{Binding Description}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="Confidence: "
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource WarningAmberBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
